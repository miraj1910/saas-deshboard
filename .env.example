# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
# Base URL for the application (used for generating callback URLs in server actions)
# Production: https://your-domain.com
# Local: http://localhost:3000
APP_URL=http://localhost:3000
# Used by client-side code for building callback URLs
# Production: https://your-domain.com
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Examples:
#   Local:    postgresql://postgres:postgres@localhost:5432/flowdesk
#   Docker:   postgresql://postgres:postgres@db:5432/flowdesk
#   Railway:  postgresql://postgres:password@railway-host:5432/flowdesk
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowdesk"

# ──────────────────────────────────────────────
# Auth.js (NextAuth v5)
# ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Required for production — MUST match your deployment URL exactly
# This is used by Auth.js to generate OAuth callback URLs (e.g., /api/auth/callback/google)
# Production: https://your-domain.com
# Local: http://localhost:3000
# ⚠️ Must be set in Vercel Environment Variables for production deployments
AUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────
# OAuth Providers
# ──────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# File Storage (UploadThing)
# ──────────────────────────────────────────────
# Get these from https://uploadthing.com/dashboard
UPLOADTHING_APP_ID=
UPLOADTHING_SECRET=

# ──────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender domain in Resend
EMAIL_FROM=FlowDesk <noreply@yourdomain.com>

# ──────────────────────────────────────────────
# Stripe
# ──────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs from https://dashboard.stripe.com/products
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# ──────────────────────────────────────────────
# Error Tracking (Sentry)
# ──────────────────────────────────────────────
# Get from https://sentry.io/settings/YOUR_ORG/projects/YOUR_PROJECT/keys/
NEXT_PUBLIC_SENTRY_DSN=
# Optional — required for source map uploads during build
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
