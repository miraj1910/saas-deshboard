# ──────────────────────────────────────────────
# Application URLs
# ──────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL — used by server actions for callback/redirect URLs in emails
# NEXT_PUBLIC_API_URL — used by client-side fetch calls
# APP_URL — server-side fallback for AUTH_URL and callback URLs
# Local:    http://localhost:3000
# Vercel:   https://your-app.vercel.app
# Custom:   https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
APP_URL=http://localhost:3000

# Support email displayed in the UI
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# DATABASE_URL — used by Prisma Client at runtime.
#               In production, use the Supabase pooler (port 6543).
#               Locally, use your local Postgres or the pooler.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Examples:
#   Local:    postgresql://postgres:postgres@localhost:5432/flowdesk
#   Docker:   postgresql://postgres:postgres@db:5432/flowdesk
#   Supabase pooler: postgresql://postgres.project:password@aws-X-region-X.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowdesk"

# DIRECT_URL — used by prisma migrate, prisma db push, etc.
#              Must point to the direct Postgres connection (not the pooler),
#              because migrations use session-level features (advisory locks,
#              prepared statements, SET statements) incompatible with PgBouncer.
#               In production, use the direct Supabase connection (port 5432).
#               Locally, same as DATABASE_URL for local Postgres (no pooler).
# Supabase direct: postgresql://postgres.project:password@db.project.supabase.co:5432/postgres
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/flowdesk"

# ──────────────────────────────────────────────
# Auth.js (NextAuth v5)
# ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Required — MUST match your deployment URL exactly.
# ⚠️ Protocol determines cookie security (Secure flag + __Secure- prefix):
#    http://  → non-secure cookies (works on localhost)
#    https:// → Secure cookies (required for production)
# ⚠️ Must match NEXT_PUBLIC_APP_URL
AUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────
# OAuth Providers
# ──────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ──────────────────────────────────────────────
# File Storage (UploadThing)
# ──────────────────────────────────────────────
# Get these from https://uploadthing.com/dashboard
UPLOADTHING_APP_ID=
UPLOADTHING_SECRET=

# ──────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender domain in Resend
EMAIL_FROM=FlowDesk <noreply@yourdomain.com>

# ──────────────────────────────────────────────
# Stripe
# ──────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs from https://dashboard.stripe.com/products
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# ──────────────────────────────────────────────
# Error Tracking (Sentry)
# ──────────────────────────────────────────────
# Get from https://sentry.io/settings/YOUR_ORG/projects/YOUR_PROJECT/keys/
NEXT_PUBLIC_SENTRY_DSN=
# Optional — required for source map uploads during build
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
