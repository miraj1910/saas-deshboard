generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Workspace {
  id             String             @id @default(uuid())
  name           String
  slug           String             @unique
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  activities     Activity[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  clientMembers  ClientMember[]
  clientRequests ClientRequest[]
  clients        Client[]
  files          FileAttachment[]
  invites        Invite[]
  invoices       Invoice[]
  notifications  Notification[]
  projects       Project[]
  subscriptions  Subscription[]
  timeEntries    TimeEntry[]
  members        WorkspaceMember[]
  settings       WorkspaceSettings?

  @@index([slug])
  @@index([deletedAt])
  @@map("workspaces")
}

model WorkspaceSettings {
  id             String    @id @default(uuid())
  workspaceId    String    @unique
  logoUrl        String?
  primaryColor   String?
  timezone       String    @default("UTC")
  companyName    String?
  companyAddress String?
  companyTaxId   String?
  theme          Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_settings")
}

model Subscription {
  id                   String             @id @default(uuid())
  workspaceId          String
  stripeSubscriptionId String?
  stripeCustomerId     String?
  plan                 Plan
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, currentPeriodEnd])
  @@map("subscriptions")
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  passwordHash       String
  name               String
  avatarUrl          String?
  userType           UserType          @default(TEAM)
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  emailVerified      DateTime?
  accounts           Account[]
  activities         Activity[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  invitedClients     ClientMember[]    @relation("ClientMemberInviter")
  clientMembers      ClientMember[]
  uploadedFiles      FileAttachment[]
  createdInvites     Invite[]          @relation("InviteCreator")
  actedNotifications Notification[]    @relation("NotificationActor")
  notifications      Notification[]
  sessions           Session[]
  assignedTasks      Task[]            @relation("TaskAssignee")
  approvedEntries    TimeEntry[]       @relation("TimeEntryApprover")
  timeEntries        TimeEntry[]
  invitedMembers     WorkspaceMember[] @relation("MemberInviter")
  workspaceMembers   WorkspaceMember[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  joinedAt    DateTime      @default(now())
  invitedById String?
  invitedBy   User?         @relation("MemberInviter", fields: [invitedById], references: [id])
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([role])
  @@map("workspace_members")
}

model Client {
  id             String           @id @default(uuid())
  workspaceId    String
  name           String
  email          String?
  phone          String?
  company        String?
  status         ClientStatus     @default(LEAD)
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  members        ClientMember[]
  clientRequests ClientRequest[]
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliverables   FileAttachment[]
  invites        Invite[]
  invoices       Invoice[]
  projects       Project[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([deletedAt])
  @@map("clients")
}

model ClientRequest {
  id          String        @id @default(uuid())
  workspaceId String
  clientId    String
  title       String
  description String?
  status      RequestStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, clientId])
  @@index([workspaceId, clientId, status])
  @@map("client_requests")
}

model ClientMember {
  id          String    @id @default(uuid())
  clientId    String
  userId      String
  workspaceId String
  joinedAt    DateTime  @default(now())
  invitedById String?
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invitedBy   User?     @relation("ClientMemberInviter", fields: [invitedById], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, userId])
  @@map("client_members")
}

model Project {
  id          String           @id @default(uuid())
  workspaceId String
  clientId    String
  name        String
  description String?
  hourlyRate  Decimal          @default(0) @db.Decimal(10, 2)
  status      ProjectStatus    @default(ACTIVE)
  startDate   DateTime?        @db.Date
  dueDate     DateTime?        @db.Date
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  files       FileAttachment[]
  client      Client           @relation(fields: [clientId], references: [id])
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]
  timeEntries TimeEntry[]

  @@index([workspaceId])
  @@index([workspaceId, clientId])
  @@index([workspaceId, status])
  @@index([deletedAt])
  @@map("projects")
}

model Task {
  id          String      @id @default(uuid())
  projectId   String
  assigneeId  String?
  title       String
  description String?
  status      TaskStatus  @default(TODO)
  dueDate     DateTime?   @db.Date
  sortOrder   Float       @default(0)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([projectId, sortOrder])
  @@index([deletedAt])
  @@map("tasks")
}

model FileAttachment {
  id           String    @id @default(uuid())
  workspaceId  String
  projectId    String?
  clientId     String?
  uploadedById String?
  name         String    @db.VarChar(512)
  originalName String    @db.VarChar(512)
  size         Int
  type         String    @db.VarChar(128)
  key          String    @db.VarChar(1024)
  url          String    @db.VarChar(2048)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  client       Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id])
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@index([clientId])
  @@index([uploadedById])
  @@map("file_attachments")
}

model TimeEntry {
  id              String            @id @default(uuid())
  workspaceId     String
  userId          String
  projectId       String
  taskId          String?
  description     String?
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int
  status          TimeEntryStatus   @default(DRAFT)
  approvedById    String?
  approvedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  invoiceItems    InvoiceLineItem[]
  approvedBy      User?             @relation("TimeEntryApprover", fields: [approvedById], references: [id])
  project         Project           @relation(fields: [projectId], references: [id])
  task            Task?             @relation(fields: [taskId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, userId])
  @@index([workspaceId, projectId])
  @@index([workspaceId, startTime, endTime])
  @@index([workspaceId, status])
  @@index([userId, startTime])
  @@index([deletedAt])
  @@map("time_entries")
}

model Invoice {
  id            String            @id @default(uuid())
  workspaceId   String
  clientId      String
  invoiceNumber String
  status        InvoiceStatus     @default(DRAFT)
  totalAmount   Decimal           @default(0) @db.Decimal(12, 2)
  issuedDate    DateTime          @db.Date
  dueDate       DateTime          @db.Date
  paidAt        DateTime?
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  lineItems     InvoiceLineItem[]
  client        Client            @relation(fields: [clientId], references: [id])
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, invoiceNumber])
  @@index([workspaceId])
  @@index([workspaceId, clientId])
  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
  @@index([deletedAt])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String     @id @default(uuid())
  invoiceId   String
  timeEntryId String?
  description String
  quantity    Decimal    @db.Decimal(10, 2)
  unitPrice   Decimal    @db.Decimal(10, 2)
  amount      Decimal    @db.Decimal(12, 2)
  sortOrder   Int        @default(0)
  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  timeEntry   TimeEntry? @relation(fields: [timeEntryId], references: [id])

  @@index([invoiceId])
  @@index([timeEntryId])
  @@map("invoice_line_items")
}

model Invite {
  id          String        @id @default(uuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  token       String        @unique
  status      InviteStatus  @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdById String?
  clientId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User?         @relation("InviteCreator", fields: [createdById], references: [id])
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([token])
  @@index([email])
  @@index([status])
  @@index([workspaceId, status])
  @@map("invites")
}

model Notification {
  id          String           @id @default(uuid())
  workspaceId String
  userId      String
  type        NotificationType
  title       String
  message     String?
  link        String?
  readAt      DateTime?
  actorId     String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id])
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, readAt])
  @@index([workspaceId, userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model AuditLog {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

model Activity {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String?
  action      String
  description String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, entityType])
  @@map("activities")
}

model ApiKey {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  name        String
  keyHash     String    @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([keyHash])
  @@map("api_keys")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

enum UserType {
  TEAM
  CLIENT
}

enum WorkspaceRole {
  OWNER
  MANAGER
  TEAM_MEMBER
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELED
}

enum NotificationType {
  TASK_ASSIGNED
  PROJECT_COMPLETED
  INVOICE_PAID
  TIME_ENTRY_APPROVED
  CLIENT_CREATED
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}
